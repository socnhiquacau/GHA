# .gitignore for Java / Maven / Spring Boot project

# Maven build output
/target/

# IntelliJ IDEA
/.idea/
*.iml
/out/

# Eclipse
.project
.classpath
/.settings/

# VS Code
.vscode/

# Generated by build tools
/generated-sources/
/generated-test-sources/
/proto-contract/target

# Logs
logs/
*.log
*.log.*
product-service.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*~
*.swp
*.tmp

# Environment files
.env
.env.local

# Archives and binaries
*.jar
*.war
*.ear

# Protobuf / protoc plugin binaries (if any accidentally committed)
*.exe
*.dll
*.so

# Maven wrapper files
/.mvn/wrapper/maven-wrapper.jar

# Docker
docker/*.log

# IDEA misc
.idea/

# Mac/Windows metadata
.DS_Store
Thumbs.db

# Ignore IntelliJ run configs
*.run

# Node (if any frontend code later)
node_modules/

# coverage
coverage/

# Sonar
.sonar/

# JetBrains
*.iws

# Other
.settings/

# Keep the gitignore itself tracked
!.gitignore

gateway-service/target/*
proto-contract/target/*
playlist-service/target/*
aggregation-worker/target/*
video-service/target/*
common-lib/target/*




